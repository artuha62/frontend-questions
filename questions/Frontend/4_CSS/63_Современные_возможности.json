        "title": "Как объявить и использовать переменную в CSS?",
        "order": 41010,
        "premium": false,
        "isPopular": false,
        "explanation": "{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"type\":\"text\",\"text\":\"Переменные в CSS объявляются через \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"--имя\"},{\"type\":\"text\",\"text\":\" внутри любого селектора (чаще всего в \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\":root\"},{\"type\":\"text\",\"text\":\"), а используются через \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"var()\"},{\"type\":\"text\",\"text\":\".\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"Объявление:\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"css\"},\"content\":[{\"type\":\"text\",\"text\":\":root {\\n  --main-color: #4a90e2;\\n  --padding: 16px;\\n}\\n\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"Использование:\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"css\"},\"content\":[{\"type\":\"text\",\"text\":\"button {\\n  color: var(--main-color);\\n  padding: var(--padding);\\n}\\n\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"--main-color\"},{\"type\":\"text\",\"text\":\" и \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"--padding\"},{\"type\":\"text\",\"text\":\" — это пользовательские CSS-переменные, а \"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"var()\"},{\"type\":\"text\",\"text\":\" подставляет их значение.\"}]}]}",
